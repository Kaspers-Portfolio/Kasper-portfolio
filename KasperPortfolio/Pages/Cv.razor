@page "/cv"

<PageTitle>CV</PageTitle>

<section class="cv-shell">
    <header class="cv-header reveal">
        <h1>Curriculum Vitae</h1>
        <span class="accent-line" aria-hidden="true"></span>
    </header>

    <div class="cv-layout">
        <section class="cv-main">
            <div class="cv-section cv-section-edu">
                <h2><span class="section-icon" aria-hidden="true"></span>Uddannelse</h2>
                <div class="cv-card reveal">
                    <div class="cv-card-header">
                        <div>
                            <h3>IT-arkitektur</h3>
                            <p class="cv-muted">Erhvervsakademiet Aarhus</p>
                        </div>
                        <span class="cv-year">2024 - 2028</span>
                    </div>
                    <p class="cv-body">
                        Fokus på digitale løsninger med vægt på softwareudvikling, forretning og organisation.
                    </p>
                </div>
                <div class="cv-card reveal reveal-delay-1">
                    <div class="cv-card-header">
                        <div>
                            <h3>HHX</h3>
                            <p class="cv-muted">Aarhus Handelsgymnasium Viby J</p>
                        </div>
                        <span class="cv-year">2016 - 2019</span>
                    </div>
                    <p class="cv-body">
                        Erhvervsøkonomi, samfundsfag og sprog med fokus på forretningsforståelse og samarbejde.
                    </p>
                </div>
                <div class="cv-card reveal reveal-delay-2">
                    <div class="cv-card-header">
                        <div>
                            <h3>Værnepligt</h3>
                            <p class="cv-muted">Flyvevåbnet Operation Support Wing, Karup</p>
                        </div>
                        <span class="cv-year">Feb 2021 - Maj 2021</span>
                    </div>
                    <p class="cv-body">
                        Grundlæggende militær uddannelse med fokus på disciplin, samarbejde og ansvar.
                    </p>
                </div>
            </div>

            <div class="cv-section cv-section-spaced cv-section-exp">
                <h2><span class="section-icon" aria-hidden="true"></span>Erfaring</h2>
                <div class="cv-card reveal">
                    <div class="cv-card-header">
                        <div>
                            <h3>Frivillig brevkasserådgiver</h3>
                            <p class="cv-muted">Cyberhus</p>
                        </div>
                        <span class="cv-year">2022 - Nu</span>
                    </div>
                    <ul class="cv-list">
                        <li>Digital rådgivning og støtte til unge i sikre rammer</li>
                        <li>Fokus på empati, kommunikation og ansvarlighed</li>
                    </ul>
                </div>
                <div class="cv-card reveal reveal-delay-1">
                    <div class="cv-card-header">
                        <div>
                            <h3>Deltidsinstruktør</h3>
                            <p class="cv-muted">Locked ApS</p>
                        </div>
                        <span class="cv-year">2024 - Nu</span>
                    </div>
                    <ul class="cv-list">
                        <li>Facilitering af oplevelser og kundekontakt</li>
                        <li>Ansvar for drift og afvikling i et teammiljø</li>
                    </ul>
                </div>
                <div class="cv-card reveal reveal-delay-2">
                    <div class="cv-card-header">
                        <div>
                            <h3>Pædagogmedhjælper</h3>
                            <p class="cv-muted">Børnehuset Unsgaard</p>
                        </div>
                        <span class="cv-year">2022 - 2024</span>
                    </div>
                    <ul class="cv-list">
                        <li>Struktur og ansvar i en hverdag med børn</li>
                        <li>Samarbejde med forældre og kolleger</li>
                    </ul>
                </div>
                <div class="cv-card reveal reveal-delay-3">
                    <div class="cv-card-header">
                        <div>
                            <h3>Områdeleder</h3>
                            <p class="cv-muted">Tivoli Friheden A/S</p>
                        </div>
                        <span class="cv-year">2016 - 2021</span>
                    </div>
                    <ul class="cv-list">
                        <li>Ledelse af team og daglig drift</li>
                        <li>Kvalitet, sikkerhed og kundeservice</li>
                    </ul>
                </div>
            </div>
        </section>

        <aside class="cv-side">
            <div class="cv-section">
                <h2><span class="section-icon" aria-hidden="true"></span>Kompetencer</h2>
                <div class="cv-card reveal">
                    <ul class="cv-list simple">
                        <li>Systemdesign & softwarearkitektur</li>
                        <li>API-udvikling & backend-forståelse</li>
                        <li>Cloud & DevOps</li>
                        <li>Databasedesign & Dataforståelse</li>
                        <li>Versionsstyring & udviklingsworkflow</li>
                        <li>Projektledelse & -styring</li>
                        <li>Agil udvikling & Samarbejde</li>
                        <li>Forretningsforståelse & analyse</li>
                        <li>Kundekontakt og ansvar</li>
                    </ul>
                </div>
            </div>

            <div class="cv-section">
                <h2><span class="section-icon" aria-hidden="true"></span>Teknologier</h2>
                <div class="cv-card reveal">
                    <h4>Backend</h4>
                    <div class="chip-row">
                        <span class="chip">C#</span>
                        <span class="chip">.NET</span>
                        <span class="chip">ASP.NET Core</span>
                        <span class="chip">EF Core</span>
                    </div>
                    <h4>Frontend</h4>
                    <div class="chip-row">
                        <span class="chip">HTML</span>
                        <span class="chip">CSS</span>
                        <span class="chip">JavaScript</span>
                    </div>
                    <h4>Data</h4>
                    <div class="chip-row">
                        <span class="chip">SQL</span>
                        <span class="chip">MongoDB</span>
                        <span class="chip">NoSQL</span>
                    </div>
                    <h4>Cloud & DevOps</h4>
                    <div class="chip-row">
                        <span class="chip">Azure</span>
                        <span class="chip">Docker</span>
                        <span class="chip">Git</span>
                    </div>
                    <h4>Værktøjer & workflow</h4>
                    <div class="chip-row">
                        <span class="chip">Git</span>
                        <span class="chip">Github</span>
                        <span class="chip">Jira</span>
                        <span class="chip">Figma</span>
                        <span class="chip">ChatGPT & Codex</span>
                    </div>
                </div>
            </div>

            <div class="cv-section">
                <h2><span class="section-icon" aria-hidden="true"></span>Sprog</h2>
                <div class="cv-card cv-card-compact reveal">
                    <ul class="cv-list simple">
                        <li>Dansk – Modersmål</li>
                        <li>Engelsk – Flydende</li>
                    </ul>
                </div>
            </div>
        </aside>
    </div>
</section>
