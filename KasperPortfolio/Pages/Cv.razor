@page "/cv"

<PageTitle>CV</PageTitle>

<section class="cv-shell">
    <header class="cv-header reveal">
        <h1>Curriculum Vitae</h1>
        <p class="cv-name">Kasper</p>
        <span class="accent-line" aria-hidden="true"></span>
    </header>

    <div class="cv-layout">
        <section class="cv-main">
            <div class="cv-section">
                <h2><span class="section-icon" aria-hidden="true"></span>Uddannelse</h2>
                <div class="cv-card reveal">
                    <div class="cv-card-header">
                        <div>
                            <h3>IT-arkitektur</h3>
                            <p class="cv-muted">IT-Universitetet i København</p>
                        </div>
                        <span class="cv-year">2023 - 2027</span>
                    </div>
                    <p class="cv-body">
                        Fokus på softwarearkitektur, cloud computing, og distribuerede systemer.
                        Specialisering i .NET økosystemet og Azure.
                    </p>
                </div>
                <div class="cv-card reveal reveal-delay-1">
                    <div class="cv-card-header">
                        <div>
                            <h3>Datatekniker</h3>
                            <p class="cv-muted">TEC Ballerup</p>
                        </div>
                        <span class="cv-year">2021 - 2023</span>
                    </div>
                    <p class="cv-body">
                        Grundlæggende programmering, database design, og webudvikling. Første introduktion
                        til C# og objektorienteret programmering.
                    </p>
                </div>
            </div>

            <div class="cv-section cv-section-spaced">
                <h2><span class="section-icon" aria-hidden="true"></span>Erfaring</h2>
                <div class="cv-card reveal">
                    <div class="cv-card-header">
                        <div>
                            <h3>Junior Developer (Praktik)</h3>
                            <p class="cv-muted">TechStartup ApS</p>
                        </div>
                        <span class="cv-year">2024 - Nu</span>
                    </div>
                    <ul class="cv-list">
                        <li>Udvikling af microservices i .NET med Docker</li>
                        <li>Implementering af CI/CD pipelines i Azure DevOps</li>
                        <li>REST API design og integration med frontend teams</li>
                    </ul>
                </div>
            </div>
        </section>

        <aside class="cv-side">
            <div class="cv-section">
                <h2><span class="section-icon" aria-hidden="true"></span>Kompetencer</h2>
                <div class="cv-card reveal">
                    <ul class="cv-list simple">
                        <li>Systemdesign &amp; arkitektur</li>
                        <li>API development</li>
                        <li>DevOps &amp; CI/CD</li>
                        <li>Database design</li>
                        <li>Agile metodikker</li>
                        <li>Git &amp; version control</li>
                    </ul>
                </div>
            </div>

            <div class="cv-section cv-section-spaced">
                <h2><span class="section-icon" aria-hidden="true"></span>Teknologier</h2>
                <div class="cv-card reveal">
                    <h4>Backend</h4>
                    <div class="chip-row">
                        <span class="chip">C#</span>
                        <span class="chip">.NET</span>
                        <span class="chip">ASP.NET Core</span>
                        <span class="chip">EF Core</span>
                    </div>
                    <h4>Cloud &amp; DevOps</h4>
                    <div class="chip-row">
                        <span class="chip">Azure</span>
                        <span class="chip">Docker</span>
                        <span class="chip">Kubernetes</span>
                        <span class="chip">Azure DevOps</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</section>
