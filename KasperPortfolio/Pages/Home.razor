@page "/"

<PageTitle>Forside</PageTitle>

<section class="home-shell">
    <div class="home-hero">
        <div class="hero-copy">
            <h1 class="hero-title reveal">Kasper</h1>
            <div class="hero-subtitle reveal reveal-delay-1">
                <span>IT-arkitektur studerende</span>
                <span class="accent-line" aria-hidden="true"></span>
            </div>
            <p class="hero-text reveal reveal-delay-2">
                Passioneret omkring moderne softwareudvikling med fokus på C#, .NET, Azure,
                og cloud-native arkitektur. Jeg brænder for at designe skalerbare systemer med
                microservices, Docker, og DevOps-principper.
            </p>
            <div class="hero-actions reveal reveal-delay-3">
                <NavLink class="hero-btn hero-btn-ghost" href="om-mig">Om mig</NavLink>
                <NavLink class="hero-btn hero-btn-primary" href="cv">Se mit CV</NavLink>
                <NavLink class="hero-btn hero-btn-secondary" href="projekter">Mine projekter</NavLink>
            </div>
            <div class="hero-icons reveal reveal-delay-4" aria-label="Kontakt links">
                <a class="icon-link" href="mailto:kontakt@eksempel.dk" aria-label="Send email">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Zm0 2.5v8h16v-8l-8 5-8-5Zm8 3.2 8-5H4l8 5Z" />
                    </svg>
                </a>
                <a class="icon-link" href="https://www.linkedin.com" aria-label="LinkedIn">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6.94 9.5H4.1V20h2.84V9.5ZM5.5 8.24a1.65 1.65 0 1 0 0-3.3 1.65 1.65 0 0 0 0 3.3Zm4.4 1.26H7.06V20H9.9v-5.52c0-1.36.26-2.68 1.95-2.68 1.66 0 1.68 1.55 1.68 2.77V20h2.84v-5.92c0-2.9-.62-5.1-4-5.1-1.61 0-2.7.88-3.14 1.71h-.04V9.5Z" />
                    </svg>
                </a>
                <a class="icon-link" href="https://github.com" aria-label="GitHub">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2.2A9.8 9.8 0 0 0 8.9 21.4c.5.1.7-.2.7-.5v-1.7c-3 .6-3.6-1.2-3.6-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.6 1 1.6 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.4-.3-4.9-1.2-4.9-5.4 0-1.2.4-2.1 1-2.9-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 4.9 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.7.8 1 1.7 1 2.9 0 4.2-2.5 5.1-4.9 5.4.4.3.8 1 .8 2.1V21c0 .3.2.6.7.5A9.8 9.8 0 0 0 12 2.2Z" />
                    </svg>
                </a>
            </div>
        </div>
        <div class="hero-photo reveal reveal--right reveal-delay-2">
            <img src="images/portrait-placeholder.svg" alt="Profilbillede af Kasper" />
        </div>
    </div>
</section>
