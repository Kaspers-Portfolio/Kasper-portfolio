@page "/projekter"

<PageTitle>Projekter</PageTitle>

<section class="projects-shell">
    <header class="projects-header">
        <h1>Projekter</h1>
        <p class="projects-subtitle">Udvalgte projekter og tekniske eksperimenter</p>
        <span class="accent-line" aria-hidden="true"></span>
    </header>

    <div class="projects-list">
        <article class="project-row">
            <div class="project-media">
                <img src="images/project-cloud.svg" alt="Cloud-native e-commerce platform" />
            </div>
            <div class="project-content">
                <h2>Cloud-native E-commerce Platform</h2>
                <p>
                    En skalerbar e-commerce platform bygget med microservices arkitektur. Systemet
                    anvender .NET, Docker, Azure Kubernetes Service, og Azure Service Bus til asynkron
                    kommunikation mellem services. Implementeret med CQRS pattern og event sourcing.
                </p>
                <div class="tag-row">
                    <span class="tag">C#</span>
                    <span class="tag">.NET</span>
                    <span class="tag">Azure</span>
                    <span class="tag">Docker</span>
                    <span class="tag">Kubernetes</span>
                    <span class="tag">Service Bus</span>
                    <span class="tag">Redis</span>
                </div>
                <div class="project-actions">
                    <a class="project-btn" href="https://github.com">GitHub</a>
                    <a class="project-btn project-btn-primary" href="https://example.com">Demo</a>
                </div>
            </div>
        </article>

        <article class="project-row project-row-reverse">
            <div class="project-media">
                <img src="images/project-devops.svg" alt="DevOps automation suite" />
            </div>
            <div class="project-content">
                <h2>DevOps Automation Suite</h2>
                <p>
                    Automatiseringsværktøj til CI/CD pipelines med integration til Azure DevOps.
                    Systemet automatiserer deployment, testing, og monitoring af .NET applikationer.
                    Inkluderer custom plugins til database migrations og environment provisioning.
                </p>
                <div class="tag-row">
                    <span class="tag">C#</span>
                    <span class="tag">.NET</span>
                    <span class="tag">Azure DevOps</span>
                    <span class="tag">PowerShell</span>
                    <span class="tag">YAML</span>
                    <span class="tag">Terraform</span>
                </div>
                <div class="project-actions">
                    <a class="project-btn" href="https://github.com">GitHub</a>
                    <a class="project-btn project-btn-primary" href="https://example.com">Demo</a>
                </div>
            </div>
        </article>

        <article class="project-row">
            <div class="project-media">
                <img src="images/project-analytics.svg" alt="Real-time analytics dashboard" />
            </div>
            <div class="project-content">
                <h2>Real-time Analytics Dashboard</h2>
                <p>
                    Real-time dashboard til business analytics med SignalR og Azure Functions. Data
                    processeres i microservices og aggregeres til et centraliseret dashboard. Systemet
                    håndterer millioner af events dagligt med lav latency.
                </p>
                <div class="tag-row">
                    <span class="tag">ASP.NET Core</span>
                    <span class="tag">SignalR</span>
                    <span class="tag">Azure Functions</span>
                    <span class="tag">SQL Server</span>
                    <span class="tag">React</span>
                    <span class="tag">TypeScript</span>
                </div>
                <div class="project-actions">
                    <a class="project-btn" href="https://github.com">GitHub</a>
                    <a class="project-btn project-btn-primary" href="https://example.com">Demo</a>
                </div>
            </div>
        </article>

        <article class="project-row project-row-reverse">
            <div class="project-media">
                <img src="images/project-gateway.svg" alt="API gateway og service mesh" />
            </div>
            <div class="project-content">
                <h2>API Gateway &amp; Service Mesh</h2>
                <p>
                    Custom API gateway implementeret med Ocelot og .NET. Håndterer authentication,
                    rate limiting, request aggregation, og service discovery. Integreret med Azure API
                    Management for production deployment.
                </p>
                <div class="tag-row">
                    <span class="tag">.NET</span>
                    <span class="tag">Ocelot</span>
                    <span class="tag">Azure API Management</span>
                    <span class="tag">OAuth 2.0</span>
                    <span class="tag">Docker</span>
                    <span class="tag">Consul</span>
                </div>
                <div class="project-actions">
                    <a class="project-btn" href="https://github.com">GitHub</a>
                    <a class="project-btn project-btn-primary" href="https://example.com">Demo</a>
                </div>
            </div>
        </article>
    </div>
</section>
